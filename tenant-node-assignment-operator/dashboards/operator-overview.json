{
    "annotations": {
        "list": [
            {
                "builtIn": 1,
                "datasource": {
                    "type": "grafana",
                    "uid": "-- Grafana --"
                },
                "enable": true,
                "hide": true,
                "iconColor": "rgba(0, 211, 255, 1)",
                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    },
    "description": "Operational overview of the Tenant Node Assignment Operator",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "title": "Reconciliation Rate",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "rate(controller_runtime_reconcile_total{controller=\"tenantnodeassignment\"}[5m])",
                    "legendFormat": "{{result}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ops",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            }
        },
        {
            "title": "Reconciliation Duration (p95)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, rate(controller_runtime_reconcile_time_seconds_bucket{controller=\"tenantnodeassignment\"}[5m]))",
                    "legendFormat": "p95"
                },
                {
                    "expr": "histogram_quantile(0.50, rate(controller_runtime_reconcile_time_seconds_bucket{controller=\"tenantnodeassignment\"}[5m]))",
                    "legendFormat": "p50"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            }
        },
        {
            "title": "Work Queue Depth",
            "type": "stat",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 0,
                "y": 8
            },
            "targets": [
                {
                    "expr": "workqueue_depth{name=\"tenantnodeassignment\"}",
                    "legendFormat": "depth"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 5
                            },
                            {
                                "color": "red",
                                "value": 20
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Reconciliation Errors",
            "type": "stat",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 6,
                "y": 8
            },
            "targets": [
                {
                    "expr": "rate(controller_runtime_reconcile_total{controller=\"tenantnodeassignment\",result=\"error\"}[5m])",
                    "legendFormat": "errors/sec"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "red",
                                "value": 0.1
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Active Leader",
            "type": "stat",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 12,
                "y": 8
            },
            "targets": [
                {
                    "expr": "leader_election_master_status",
                    "legendFormat": "{{name}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "options": {
                                "0": {
                                    "text": "Standby"
                                }
                            },
                            "type": "value"
                        },
                        {
                            "options": {
                                "1": {
                                    "text": "LEADER"
                                }
                            },
                            "type": "value"
                        }
                    ],
                    "thresholds": {
                        "steps": [
                            {
                                "color": "yellow",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Go Goroutines",
            "type": "timeseries",
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 18,
                "y": 8
            },
            "targets": [
                {
                    "expr": "go_goroutines",
                    "legendFormat": "goroutines"
                }
            ]
        },
        {
            "title": "TNA Resources by Phase",
            "type": "piechart",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 14
            },
            "targets": [
                {
                    "expr": "compute_platform_cr_phase_total",
                    "legendFormat": "{{phase}}"
                }
            ]
        },
        {
            "title": "Go Memory Usage",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 14
            },
            "targets": [
                {
                    "expr": "go_memstats_alloc_bytes",
                    "legendFormat": "alloc"
                },
                {
                    "expr": "go_memstats_sys_bytes",
                    "legendFormat": "sys"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes"
                }
            }
        }
    ],
    "schemaVersion": 39,
    "tags": [
        "operator",
        "compute-platform",
        "tenant-assignment"
    ],
